---
interface Props {
  date: Date;
  lang?: "en" | "es";
}

const { date, lang = "en" } = Astro.props;
const locale = lang === "es" ? "es-ES" : "en-US";
---

<time datetime={date.toISOString()}>
  {
    date.toLocaleDateString(locale, {
      month: "long",
      day: "2-digit",
      year: "numeric",
    })
  }
</time>
